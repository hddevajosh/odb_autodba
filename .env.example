# Preferred Oracle connection names.
# Older DB_* aliases are also supported; see README.md.
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=FREEPDB1
ORACLE_USER=system
ORACLE_PASSWORD=oracle
ORACLE_SYSDBA=false
ORACLE_DSN=

# Compatible aliases if you are migrating from the older AutoDBA layout.
DB_HOST=
DB_PORT=
DB_SERVICE=
DB_USER=
DB_PASSWORD=
DB_DSN=

ENABLE_HOST_CHECKS=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
